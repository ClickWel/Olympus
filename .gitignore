# ============ SECRETS - never commit ============
# Env files (any flavor)
*.env
.env*
**/MASTER_API_KEYS.env
**/api_keys*
**/credentials*
**/secrets*

# Known secret-bearing scripts
crush/start-crush.bat
scripts/**/nr_introspect*.ps1
memory/talos_500_fix.md

# Keys, certs, tokens
*_key.*
*_token.*
*.key
*.pem
*.p12
*.pfx

# ============ Claude Code internals ============
.claude/worktrees/
.claude/projects/
.claude/sessions/

# ============ Temp / cache / build ============
tmp/
temp/
**/__pycache__/
**/*.pyc
**/*.pyo
node_modules/
*.log
.aider*

# ============ OS junk ============
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
System Volume Information/
.DS_Store
