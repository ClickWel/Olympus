{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_TOOL_SEARCH": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(pnpm test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm build*)",
      "Bash(pnpm run*)",
      "Bash(bun*)",
      "Bash(ls*)",
      "Bash(dir*)",
      "Bash(python*)",
      "mcp__filesystem__read_text_file",
      "mcp__filesystem__list_directory",
      "mcp__filesystem__list_allowed_directories"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh issue*)",
      "Bash(gh release*)",
      "Bash(npm publish*)",
      "Bash(curl* slack.com*)",
      "Bash(curl* trello.com*)",
      "Bash(curl.exe* slack.com*)",
      "Bash(curl.exe* trello.com*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -Command \"Get-Process -Name 'node','node20' -ErrorAction SilentlyContinue | Where-Object { $_.StartTime -lt (Get-Date).AddHours(-1) } | ForEach-Object { Stop-Process -Id $_.Id -Force }\"",
            "shell": "powershell",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "powershell -ExecutionPolicy Bypass -File C:/Users/click/.claude/statusline-command.ps1"
  },
  "alwaysThinkingEnabled": false,
  "effortLevel": "low",
  "fastMode": true,
  "autoUpdatesChannel": "latest",
  "voice": {
    "enabled": true,
    "mode": "tap"
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "voiceEnabled": true,
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "--allowed-dirs",
        "D:\\Olympus",
        "D:\\Clawdbot",
        "D:\\Shared",
        "D:\\Atlas",
        "D:\\Argus",
        "D:\\Hermes",
        "D:\\HW",
        "C:\\Users\\click\\.clawdbot-dev"
      ]
    }
  }
}
